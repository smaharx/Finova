# Example env
DATABASE_URL=sqlite:///./expenses.db
# For docker postgres use:
# DATABASE_URL=postgresql://finova:finova_pass@db:5432/finova

# Optional: if you want the container to download the ML model at startup,
# set MODEL_URL to a publicly accessible URL (S3, GCS, or HTTP server) where
# a valid `saved_brain.pkl` file can be downloaded.
# MODEL_URL=https://example-bucket.s3.amazonaws.com/saved_brain.pkl
